# ============================================================
#  > ClawBox EXAMPLE Configuration <
# ============================================================

# --- Network + VM Configuration ---
HOST_IP="<host-ip>"
VM_IP="<vm-ip>"
VM_USER="your-vm-username"
VM_USER_PATH="/Users/<vm-user>"
VM_HOST="<vm-user>@<vm-ip>"
VM_RUNTIME_PATH="/Users/<vm-user>/ClawBox"
VM_MACHINE_NAME="Your VM Name in UTM"

# --- Model Configuration ---
MODEL_PATH="/Users/<vm-user>/models/model.gguf"

# --- LLaMA Server Configuration ---
LLAMA_BIN="$HOME/ai/llama.cpp/build/bin/llama-server"
LLAMA_HOST="0.0.0.0"
LLAMA_PORT="11434"
LLAMA_CTX="16384"
LLAMA_EXTRA_ARGS=""
LLAMA_BASE_URL="http://<host-ip>:11434/v1"
LLAMA_EXTERNAL="false"

# --- VM Discovery Metadata ---
# Retained for VM SSH recovery and IP discovery despite the legacy name.
FIREWALL_SHARED_SUBNET="192.168.64.0/24"

# --- OpenClaw Configuration ---
OPENCLAW_PROVIDER_NAME="your-provider-name"
OPENCLAW_DEFAULT_MODEL="local"
OPENCLAW_GATEWAY_MODE="local"
OPENCLAW_AUTOSTART="<true-or-false>"
