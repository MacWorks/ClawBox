#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() {
  cat <<EOF
ClawBox CLI

Usage:
  ./clawbox <command>

Commands:
  setup       Run interactive setup
  status      Show system status
  model       Switch a host model (primary or embeddings)
  qualify     Run VM-side model qualification scenarios
  openclaw    OpenClaw maintenance commands
  help        Show this help message

Options:
  -h, --help  Show this help message

Examples:
  ./clawbox setup
  ./clawbox status
  ./clawbox model
  ./clawbox model primary
  ./clawbox model metadata /path/to/model.gguf --set-display-name "Display Name"
  ./clawbox model embedding
  ./clawbox model embeddings
  ./clawbox qualify
  ./clawbox qualify --profile fast
  ./clawbox qualify --profile full
  ./clawbox qualify history
  ./clawbox qualify compare
  ./clawbox qualify report --latest
  ./clawbox qualify badge --latest
  ./clawbox openclaw reset
EOF
}

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  setup)
    exec "$BASE_DIR/scripts/setup.sh" "$@"
    ;;
  status)
    exec "$BASE_DIR/scripts/status.sh" "$@"
    ;;
  model)
    exec "$BASE_DIR/scripts/model.sh" "$@"
    ;;
  qualify)
    exec "$BASE_DIR/scripts/qualify.sh" "$@"
    ;;
  openclaw)
    exec "$BASE_DIR/scripts/openclaw.sh" "$@"
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    echo "Unknown command: $cmd"
    echo
    show_help
    exit 1
    ;;
esac
